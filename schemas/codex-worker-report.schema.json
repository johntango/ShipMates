{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "taskId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        },
        "required": [
          "command",
          "result"
        ]
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "taskId",
    "status",
    "summary",
    "branch",
    "commit",
    "files",
    "tests",
    "risks"
  ]
}
